.venv/
.vscode/
.DS_Store

# environment variables (api_key included)
.env

**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Local-only machine state, scratch copies, downloaded archives, and run dumps.
.local/

# Generated experiment artifacts.
experiments/**/outputs*/*
!experiments/**/outputs*/.gitkeep
experiments/**/logs*/*
!experiments/**/logs*/.gitkeep
experiments/**/results*/*
!experiments/**/results*/.gitkeep
!experiments/**/results*/README.md

# S4 isolated candidate workspace (full FlowTune source tree copy).
experiments/**/impl_compare/candidate_modified/workspace/
# S4 build logs are small enough to track, but build artifacts are not.
experiments/**/impl_compare/*/build.log
experiments/**/impl_compare/comparison/logs/

# Legacy top-level run directories, kept ignored if regenerated locally.
/outputs/
/logs/
/results/

*.o
*.a

third_party/

# local planning document
to_do_list.md
